{
  "name": "robinhood-exporter",
  "version": "0.1.0",
  "private": true,
  "description": "Firefox WebExtension that exports stock and crypto positions from robinhood.com to a local CSV file by reading the rendered DOM. Not affiliated with Robinhood Markets, Inc.",
  "type": "module",
  "scripts": {
    "build": "vite build && vite build -c vite.content.config.ts",
    "icons": "node scripts/rasterize-icons.mjs",
    "typecheck": "tsc --noEmit",
    "lint:ext": "web-ext lint --source-dir=./dist",
    "run:firefox": "web-ext run --source-dir=./dist --target=firefox-desktop"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/firefox-webext-browser": "^143.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "web-ext": "^10.2.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
